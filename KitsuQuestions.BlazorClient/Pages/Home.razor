@page "/"
@inject HttpClient Http

<PageTitle>Kitsu Questions — Goals</PageTitle>

<div class="shrine-page">

<img src="images/kitsu-greeting.png"
     alt="Kitsu the kitsune"
     class="kitsu-mascot" />

@if (errorMessage is not null)
{
    <p style="color: crimson;">@errorMessage</p>
}

@if (!showAddForm)
{
    <button class="btn-foxfire" @onclick="() => showAddForm = true">
        + Add a goal
    </button>
}

<div class="home-columns">
    @if (showAddForm)
    {
        <div class="parchment-panel add-goal-panel">
            <button class="panel-close"
                    @onclick="() => showAddForm = false"
                    aria-label="Close">
                ×
            </button>

            <section>
                <h2>Add a goal</h2>
                <input @bind="newTitle" placeholder="Title" />
                <input @bind="newDescription" placeholder="Description (optional)" />
                <button class="btn-foxfire" @onclick="CreateGoal" disabled="@isBusy">Add</button>
            </section>
        </div>
    }

    <div class="parchment-panel">
        @if (goals is null)
        {
            <p><em>Loading…</em></p>
        }
        else if (goals.Count == 0)
        {
            <p>No goals yet. Add one above.</p>
        }
        else
        {
            <ul>
                @foreach (var goal in goals)
                {
                    <li style="margin-bottom: 1rem;">
                        <strong>@goal.Title</strong> — @goal.Status
                        @if (!string.IsNullOrWhiteSpace(goal.Description))
                        {
                            <div><small>@goal.Description</small></div>
                        }

                            <div style="margin-top: 0.4rem; display: flex; gap: 0.4rem;">
                                <button class="btn-sand" @onclick="() => OpenEditModal(goal)">
                                    Edit
                                </button>
                                @if (goal.Status == GoalStatus.ToLearn)
                                {
                                    <button class="btn-foxfire"
                                            @onclick='() => ChangeStatus(goal.Id, "move-to-learning")'>
                                        Start learning
                                    </button>
                                }
                                @if (goal.Status == GoalStatus.Learning)
                                {
                                    <button class="btn-foxfire"
                                            @onclick='() => ChangeStatus(goal.Id, "fulfill")'>
                                        Mark fulfilled
                                    </button>
                                    <button class="btn-sand"
                                            @onclick='() => ChangeStatus(goal.Id, "move-to-tolearn")'>
                                        Back to to-learn
                                    </button>
                                }
                                <button class="btn-crimson" @onclick='() => goalIdPendingDelete = goal.Id'>Delete</button>
                            </div>
                    </li>
                }
            </ul>
        }
    </div>
</div>

</div>

@if (goalIdPendingDelete is not null)
{
    <div class="modal-backdrop" @onclick="() => goalIdPendingDelete = null">
        <div class="modal-panel parchment-panel" @onclick:stopPropagation="true">
            <h2>Really delete this goal?</h2>
            <p>This cannot be undone.</p>
            <div style="display: flex; gap: 0.6rem; justify-content: flex-end;">
                <button class="btn-sand" @onclick="() => goalIdPendingDelete = null">
                    Cancel
                </button>
                <button class="btn-crimson" @onclick="ConfirmDelete">
                    Yes, delete
                </button>
            </div>
        </div>
    </div>
}

@if (editingGoal is not null)
{
    <div class="modal-backdrop" @onclick="CloseEditModal">
        <div class="modal-panel parchment-panel" @onclick:stopPropagation="true">
            <h2>Edit goal</h2>
            <input @bind="editTitle" placeholder="Title" />
            <input @bind="editDescription" placeholder="Description (optional)" />
            <div style="display: flex; gap: 0.6rem; justify-content: flex-end; margin-top: 1rem;">
                <button class="btn-sand" @onclick="CloseEditModal">Cancel</button>
                <button class="btn-foxfire" @onclick="SaveEdit" disabled="@isBusy">Save</button>
            </div>
        </div>
    </div>
}

@code {
    private List<GoalDto>? goals;
    private string newTitle = "";
    private string newDescription = "";
    private string? errorMessage;
    private bool isBusy;
    private bool showAddForm = false;
    private int? goalIdPendingDelete = null;
    private GoalDto? editingGoal;   // null = modal closed; a value = edit modal open for this goal
    private string editTitle = "";
    private string editDescription = "";

    protected override async Task OnInitializedAsync() => await LoadGoals();

    private async Task LoadGoals()
    {
        try
        {
            errorMessage = null;
            goals = await Http.GetFromJsonAsync<List<GoalDto>>("api/Goals");
        }
        catch (Exception ex)
        {
            errorMessage = $"Couldn't reach the API: {ex.Message}";
            goals = new List<GoalDto>();
        }
    }

    private async Task CreateGoal()
    {
        if (string.IsNullOrWhiteSpace(newTitle)) return;

        isBusy = true;
        try
        {
            var dto = new CreateGoalDto
            {
                Title = newTitle.Trim(),
                Description = string.IsNullOrWhiteSpace(newDescription) ? null : newDescription.Trim()
            };
            var response = await Http.PostAsJsonAsync("api/Goals", dto);

            if (response.IsSuccessStatusCode)
            {
                newTitle = "";
                newDescription = "";
                await LoadGoals();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"Create failed ({(int)response.StatusCode}): {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Create failed: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task ChangeStatus(int id, string action)
    {
        try
        {
            var response = await Http.PostAsync($"api/Goals/{id}/{action}", null);
            if (response.IsSuccessStatusCode)
                await LoadGoals();
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"Status change failed ({(int)response.StatusCode}): {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Status change failed: {ex.Message}";
        }
    }

    private void OpenEditModal(GoalDto goal)
    {
        editingGoal = goal;
        editTitle = goal.Title;
        editDescription = goal.Description ?? "";
    }

    private void CloseEditModal()
    {
        editingGoal = null;
        editTitle = "";
        editDescription = "";
    }

    private async Task SaveEdit()
    {
        if (editingGoal is null) return;
        if (string.IsNullOrWhiteSpace(editTitle)) return;

        isBusy = true;
        try
        {
            var dto = new UpdateGoalDto
            {
                Title = editTitle.Trim(),
                Description = string.IsNullOrWhiteSpace(editDescription) ? null : editDescription.Trim(),
                CategoryId = editingGoal.CategoryId   // preserve whatever was set
            };
            var response = await Http.PutAsJsonAsync($"api/Goals/{editingGoal.Id}", dto);

            if (response.IsSuccessStatusCode)
            {
                CloseEditModal();
                await LoadGoals();
            }
            else
            {
                var body = await response.Content.ReadAsStringAsync();
                errorMessage = $"Edit failed ({(int)response.StatusCode}): {body}";
            }
        }
        catch (Exception ex)
        {
            errorMessage = $"Edit failed: {ex.Message}";
        }
        finally
        {
            isBusy = false;
        }
    }

    private async Task DeleteGoal(int id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/Goals/{id}");
            if (response.IsSuccessStatusCode)
                await LoadGoals();
            else
                errorMessage = $"Delete failed: {(int)response.StatusCode}";
        }
        catch (Exception ex)
        {
            errorMessage = $"Delete failed: {ex.Message}";
        }
    }

    private async Task ConfirmDelete()
    {
        if (goalIdPendingDelete is null) return;

        var id = goalIdPendingDelete.Value;
        goalIdPendingDelete = null;   // close modal immediately
        await DeleteGoal(id);          // then do the actual work
    }
}